  "validationRules": {
    "nome": {
      "required": true,
      "minLength": 3,
      "maxLength": 100,
      "pattern": "^[a-zA-ZÀ-ÿ\\s]+$"
    },
    "formacao": {
      "required": true,
      "minLength": 2,
      "maxLength": 150
    },
    "nivel": {
      "required": true,
      "enum": ["júnior", "pleno", "sênior", "junior", "senior"]
    },
    "horas": {
      "required": true,
      "type": "number",
      "min": 1,
      "max": 500
    },
    "cidade": {
      "required": true,
      "minLength": 2,
      "maxLength": 100
    },
    "data": {
      "required": true,
      "pattern": "^\\d{2}/\\d{2}/\\d{4}$",
      "example": "16/02/2026"
    },
    "contribuicao": {
      "required": false,
      "maxLength": 200
    },
    "nomeResponsavel": {
      "required": false,
      "maxLength": 100
    }
  },
  "notes": {
    "formato_data": "Sempre use o formato DD/MM/AAAA",
    "nivel_valores": "Aceita 'júnior', 'pleno', 'sênior' (com ou sem acento)",
    "nome_formato": "Nome completo do aluno, sem números ou caracteres especiais",
    "horas_minimo": "Mínimo de 1 hora, máximo recomendado de 500 horas",
    "contribuicao_opcional": "Campo opcional que complementa a descrição do certificado",
    "responsavel_opcional": "Se não informado, usa apenas 'Educly - Educação digital'"
  },
